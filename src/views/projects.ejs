<%- include('partials/header') %>

    <main>
        <h1>
            <%= title %>
        </h1>
        <h2>Upcoming Service Projects</h2>
        <ul>
            <% projects.forEach(project => { %>
                <li><strong><%= project.project_date.toLocaleDateString('en-US', { year: 'numeric' ,month: 'long' , day: 'numeric' }) %></strong>: <%= project.title %> (<%= project.name %>)</li>
            <% }); %>
        </ul>
    </main>

    <%- include('partials/footer') %>